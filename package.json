{
  "name": "professor-followup",
  "version": "1.1.0",
  "private": true,
  "description": "Finds AI professors, sends personalized first-contact emails, and auto-follows-up with non-repliers.",
  "type": "commonjs",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "token": "node get-token.js",
    "run": "node followup.js",
    "dry": "node followup.js --dry-run",
    "discover": "node discover.js",
    "outreach": "node outreach.js",
    "sheets:setup": "node setup-sheets.js",
    "replies": "node check-replies.js",
    "investor:people": "node discover-investor-people.js",
